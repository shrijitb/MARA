          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "mara_position_unrealized_pnl_usd" },
            "properties": [
              { "id": "displayName", "value": "Unrealized PnL (USD)" },
              { "id": "unit", "value": "currencyUSD" },
