#!/usr/bin/env python3
"""
Arca CLI - Launch dashboard as popup or manage Arca installation
Usage: arca [command]
Commands:
  launch          Launch dashboard popup
  install         Run installation (alias for install.sh)
  status          Show Arca status
  logs            Show logs
  stop            Stop Arca services
  start           Start Arca services
  restart         Restart Arca services
"""

import sys
import os
import subprocess
import json
import time
import webbrowser
from pathlib import Path
from typing import Optional

# Configuration
ARCA_DIR = os.environ.get('ARCA_DIR', os.path.expanduser('~/arca'))
DASHBOARD_URL = "http://localhost:3000"
HYPERVISOR_URL = "http://localhost:8000"

def run_cmd(cmd, capture_output=True, check=True):
    """Run a command and return result"""
    try:
        result = subprocess.run(
            cmd, shell=True, capture_output=capture_output,
            text=True, check=check
        )
        return result
    except subprocess.CalledProcessError as e:
        print(f"Error running command: {cmd}")
        if e.stderr:
            print(f"Error: {e.stderr}")
        return None


def _compose_args() -> str:
    """Return -f flags for docker compose based on which files are present."""
    base = Path(ARCA_DIR) / "docker-compose.yml"
    profile = Path(ARCA_DIR) / "docker-compose.profile.yml"
    args = f"-f {base}"
    if profile.exists():
        args += f" -f {profile}"
    return args

def check_service_health(url: str, timeout: int = 5) -> bool:
    """Check if a service is healthy"""
    try:
        import urllib.request
        urllib.request.urlopen(url, timeout=timeout)
        return True
    except:
        return False

def get_hardware_profile() -> Optional[dict]:
    """Get hardware profile from .hardware_profile.json"""
    profile_file = Path(ARCA_DIR) / '.hardware_profile.json'
    if profile_file.exists():
        try:
            with open(profile_file) as f:
                return json.load(f)
        except:
            pass
    return None

def launch_dashboard_popup():
    """Launch dashboard as popup window"""
    print("🚀 Launching Arca Dashboard...")

    # Check if Arca is running
    if not check_service_health(HYPERVISOR_URL):
        print("⚠️  Arca services not running. Starting services...")
        start_services()

        # Wait for services to be ready
        print("⏳ Waiting for services to be ready...")
        for i in range(30):
            if check_service_health(HYPERVISOR_URL):
                print("✅ Services are ready!")
                break
            time.sleep(2)
        else:
            print("❌ Services failed to start. Please check logs with: arca logs")
            return False

    # Launch dashboard
    print(f"🌐 Opening dashboard at {DASHBOARD_URL}")
    webbrowser.open(DASHBOARD_URL)

    return True

def start_services():
    """Start Arca services"""
    os.chdir(ARCA_DIR)

    if not (Path(ARCA_DIR) / "docker-compose.yml").exists():
        print("❌ docker-compose.yml not found. Please run 'arca install' first.")
        return False

    print("🚀 Starting Arca services...")
    result = run_cmd(f"docker compose {_compose_args()} up -d")
    if result is None:
        return False

    print("✅ Services started")
    return True

def stop_services():
    """Stop Arca services"""
    os.chdir(ARCA_DIR)
    print("🛑 Stopping Arca services...")
    result = run_cmd(f"docker compose {_compose_args()} down")
    if result is None:
        return False
    print("✅ Services stopped")
    return True

def show_status():
    """Show Arca status"""
    print("📊 Arca Status")
    print("=" * 50)

    # Check hardware profile
    profile = get_hardware_profile()
    if profile:
        print(f"Hardware Profile: {profile.get('board', 'unknown')} ({profile.get('arch', 'unknown')})")
        print(f"CPU: {profile.get('cpu_model', 'unknown')} ({profile.get('cpu_cores', '?')} cores)")
        print(f"RAM: {profile.get('ram_mb', 0)}MB")
        print(f"GPU: {profile.get('gpu', 'none')}")
    else:
        print("Hardware Profile: Not detected")

    print()

    # Check services
    services = [
        ("Hypervisor", HYPERVISOR_URL),
        ("Dashboard", DASHBOARD_URL),
    ]
    
    for name, url in services:
        status = "✅ Running" if check_service_health(url) else "❌ Stopped"
        print(f"{name:12}: {status}")
    
    # Check Docker containers
    print()
    print("🐳 Docker Containers:")
    result = run_cmd(
        f"docker compose {_compose_args()} ps --format 'table {{{{.Name}}}}\\t{{{{.Status}}}}\\t{{{{.Ports}}}}'",
        capture_output=True, check=False,
    )
    if result:
        print(result.stdout)

def show_logs():
    """Show Arca logs"""
    os.chdir(ARCA_DIR)
    print("📋 Arca Logs (last 100 lines)")
    print("=" * 50)
    # capture_output=False lets docker's output stream directly to the terminal.
    run_cmd(f"docker compose {_compose_args()} logs --tail=100", capture_output=False)

def install_arca():
    """Run Arca installation"""
    print("📦 Installing Arca...")
    
    # Download and run install script
    install_script = Path(ARCA_DIR) / "install.sh"
    
    if not install_script.exists():
        print("❌ install.sh not found. Please download Arca first.")
        return False
    
    os.chdir(ARCA_DIR)
    result = run_cmd("bash install.sh")
    if result is None:
        return False
    
    print("✅ Installation completed!")
    return True

def main():
    """Main CLI entry point"""
    if len(sys.argv) < 2:
        print(__doc__)
        return
    
    command = sys.argv[1].lower()
    
    if command == "launch":
        launch_dashboard_popup()
    elif command == "install":
        install_arca()
    elif command == "status":
        show_status()
    elif command == "logs":
        show_logs()
    elif command == "stop":
        stop_services()
    elif command == "start":
        start_services()
    elif command == "restart":
        stop_services()
        time.sleep(2)
        start_services()
    else:
        print(f"Unknown command: {command}")
        print(__doc__)

if __name__ == "__main__":
    main()